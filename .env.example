# SQLite-Datei für Payload (relativ zum Projekt-Root)
DATABASE_URI=file:./data/payload.db

# Payload-Secret (32+ Zeichen) — generiere mit: openssl rand -hex 32
PAYLOAD_SECRET=

# Öffentliche Basis-URL (ohne trailing slash)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Optional: Drosselt Payload's interne Telemetrie
NEXT_TELEMETRY_DISABLED=1

# SMTP für Anfrage-Benachrichtigungen (Mittwald-Postfach).
# Die genauen Werte stehen in mStudio beim Postfach unter
# "E-Mail-Programm einrichten". Ohne SMTP_HOST werden Mails nur
# in die Server-Konsole geschrieben (Dev-Fallback).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=kontakt@wedding-kinemedia.de
SMTP_PASS=
SMTP_FROM=kontakt@wedding-kinemedia.de
# Empfänger der Benachrichtigungen (Default: kontakt@wedding-kinemedia.de)
CONTACT_NOTIFY_TO=
