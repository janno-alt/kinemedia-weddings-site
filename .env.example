# SQLite-Datei für Payload (relativ zum Projekt-Root)
DATABASE_URI=file:./data/payload.db

# Payload-Secret (32+ Zeichen) — generiere mit: openssl rand -hex 32
PAYLOAD_SECRET=

# Öffentliche Basis-URL (ohne trailing slash)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Optional: Drosselt Payload's interne Telemetrie
NEXT_TELEMETRY_DISABLED=1
